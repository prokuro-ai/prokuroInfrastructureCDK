# Copy to .env and fill in values before deploy.

# GitHub PAT with repo scope — required for first deploy (creates Secrets Manager entry).
# After first deploy, remove from .env; CDK reads the existing secret on subsequent deploys.
GITHUB_TOKEN=

# Digi-Key API credentials — required for first Backend deploy (creates secret).
# After first deploy, remove from .env; ECS reads the existing Secrets Manager secret.
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
