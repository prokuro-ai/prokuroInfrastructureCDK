# Copy to .env and fill in values before deploy.
# Required for first Amplify deploy only — creates the Secrets Manager secret.
GITHUB_TOKEN=

# Custom domain (optional).
DOMAIN_NAME=

# Nexar API credentials — required for first BackendStack deploy (creates secret).
# After first deploy, remove from .env; ECS reads the existing Secrets Manager secret.
NEXAR_CLIENT_ID=
NEXAR_CLIENT_SECRET=
